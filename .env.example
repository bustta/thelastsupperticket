# The Last Supper Ticket Scraper - Environment Variables Template
# Copy this file to .env and fill in your actual values

# Target configs: ticketType|url (separate multiple entries with ';')
TARGET_CONFIGS=Ticket only|https://cenacolovinciano.vivaticket.it/en/event/cenacolo-vinciano/151991;Ticket + English guided tour|https://cenacolovinciano.vivaticket.it/en/event/cenacolo-visite-guidate-a-orario-fisso-in-inglese/238363

# Backward-compatible single target URL (used only when TARGET_CONFIGS and TARGET_URLS are not set)
# TARGET_URL=https://cenacolovinciano.vivaticket.it/en/event/cenacolo-vinciano/151991

# Telegram Bot Configuration
# Get TELEGRAM_BOT_TOKEN by creating a bot with @BotFather on Telegram
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Telegram User IDs to receive notifications
# Can be:
#   - Single numeric ID: 3345678
#   - Multiple IDs (comma-separated): 3345678,1234567890
#   - Username (not recommended, use numeric ID): @username
TELEGRAM_USER_IDS=3345678

# Enable Telegram notifications (true/false)
TELEGRAM_ENABLED=true
